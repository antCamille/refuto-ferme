# ============================================================
# REFUTO LA FERME URBAINE — Environment Variables
# ============================================================
# 1. Copy this file and rename it to: .env.local
# 2. Fill in your values from Supabase dashboard
# 3. NEVER commit .env.local to GitHub (it's in .gitignore)
# ============================================================

# From Supabase > Project Settings > API
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY_HERE

# These same values go into Vercel > Project > Settings > Environment Variables
