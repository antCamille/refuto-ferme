# ============================================================
# REFUTO LA FERME URBAINE — Environment Variables
# ============================================================
# 1. Copy this file and rename it to: .env.local
# 2. Fill in your values from Supabase dashboard
# 3. NEVER commit .env.local to GitHub
# ============================================================

# From Supabase > Project Settings > API
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_OR_PUBLISHABLE_KEY_HERE

# Keep this false for now. Your previous realtime attempt caused black screens.
VITE_ENABLE_REALTIME=false

# Stable background refresh without interrupting forms.
VITE_POLL_INTERVAL_MS=30000

# edge = send via Supabase Edge Function; log = save only in emails_log for testing
VITE_EMAIL_MODE=edge
